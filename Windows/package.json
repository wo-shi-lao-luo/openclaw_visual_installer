{
  "name": "openclaw-windows-installer",
  "private": true,
  "main": "dist-gui/main/main/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:exe": "npm run build && npx pkg launcher/installer-launcher.cjs --config package.json --targets node18-win-x64 --output dist/OpenClawInstaller.exe",
    "start": "npm run build && node dist/src/runtime/cli.js",
    "mvp": "npm run start",
    "mvp:auto": "npm run build && node dist/src/runtime/cli.js --auto",
    "mvp:uninstall": "npm run build && node dist/src/runtime/cli.js --uninstall --auto",
    "build:gui:main": "tsc -p gui/tsconfig.main.json",
    "build:gui:renderer": "vite build -c gui/vite.config.ts",
    "build:gui": "npm run build && npm run build:gui:main && npm run build:gui:renderer",
    "dev:gui": "concurrently -k -n vite,main,electron \"vite -c gui/vite.config.ts\" \"tsc -p gui/tsconfig.main.json --watch\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "dist:gui": "npm run build:gui && electron-builder --config gui/electron-builder.yml --win nsis",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "pkg": {
    "scripts": [
      "dist/src/**/*.js"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.21",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  }
}
