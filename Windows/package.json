{
  "name": "openclaw-windows-installer",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:exe": "npm run build && npx pkg launcher/installer-launcher.cjs --config package.json --targets node18-win-x64 --output dist/OpenClawInstaller.exe",
    "start": "npm run build && node dist/src/runtime/cli.js",
    "mvp": "npm run start",
    "mvp:auto": "npm run build && node dist/src/runtime/cli.js --auto",
    "mvp:uninstall": "npm run build && node dist/src/runtime/cli.js --uninstall --auto",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "pkg": {
    "scripts": [
      "dist/src/**/*.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
