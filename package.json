    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.1",
    "vitest": "^2.0.3"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
